{
  "name": "ficha-lucrativa",
  "private": true,
  "version": "0.1.0",
  "description": "SaaS WhatsApp de precificação para pequeno food BR — bot Lucrô",
  "author": "Luiz Curti",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "start": "pnpm --filter api start",
    "start:worker": "pnpm --filter api start:worker",
    "typecheck": "pnpm -r run typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "pnpm -r run test",
    "db:migrate": "pnpm --filter api prisma migrate dev",
    "db:seed": "pnpm --filter api db:seed",
    "db:studio": "pnpm --filter api prisma studio"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.6.3"
  }
}
