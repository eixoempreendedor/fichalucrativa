# ─── Core ────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
API_BASE_URL=http://localhost:3001
WEB_BASE_URL=http://localhost:3000
LOG_LEVEL=debug

# ─── Database ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ficha_lucrativa
REDIS_URL=redis://localhost:6379

# ─── LLM providers ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_MAIN=claude-sonnet-4-6
ANTHROPIC_MODEL_ROUTER=claude-haiku-4-5-20251001
OPENAI_API_KEY=sk-...
OPENAI_WHISPER_MODEL=whisper-1

# ─── WhatsApp (Z-API) ────────────────────────────────────────────────
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
ZAPI_WEBHOOK_SECRET=change-me-random-hex

# ─── Pagamento (Asaas) ───────────────────────────────────────────────
ASAAS_API_KEY=
ASAAS_API_BASE=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_SECRET=change-me-random-hex

# ─── Storage (Cloudflare R2) ─────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ficha-lucrativa-media
R2_PUBLIC_URL=https://media.fichalucrativa.com.br

# ─── Auth (magic link) ───────────────────────────────────────────────
JWT_SECRET=change-me-random-long-hex
MAGIC_LINK_FROM_EMAIL=lucro@fichalucrativa.com.br
RESEND_API_KEY=

# ─── Observabilidade ─────────────────────────────────────────────────
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=ficha-lucrativa

# ─── Feature flags ───────────────────────────────────────────────────
FEATURE_IMAGE_INPUT=true
FEATURE_AUDIO_INPUT=true
FEATURE_PAYWALL=false

# ─── Plan limits ─────────────────────────────────────────────────────
PLAN_TRIAL_FICHAS=1
PLAN_BASIC_MSG_PER_DAY=50
PLAN_PRO_MSG_PER_DAY=200
PLAN_AUDIO_MAX_SECONDS=120
